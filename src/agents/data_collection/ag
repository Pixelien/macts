    agent_name = "data_collection"
    heartbeat_interval = 5.0

    def __init__(self, *args: Any, **kwargs: Any) -> None:
        super().__init__(*args, **kwargs)
        self._active_symbols: set[str] = set()
        self._ws_connections: dict[int, Any] = {}   # connection_id -> ws_client
        self._symbol_to_connection: dict[str, int] = {}
        self._max_streams_per_conn = self.config.exchange.rate_limits.get(
            "ws_max_streams_per_connection", 200
        )
        self._max_connections = self.config.exchange.rate_limits.get(
            "ws_max_connections", 10
        )

    async def _initialize(self) -> None:
