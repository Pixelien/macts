    async def _poll_open_interest(self) -> None:
        """OpenInterest verisini REST'ten periyodik olarak çek.

        Binance WebSocket'te OI streaming yok, REST polling gerekli.
        """
        interval = self.config.data_collection.streams.get("open_interest", {}).get(
            "poll_interval_seconds", 60
        )
        while not self._stop_event.is_set():
            try:
                # TODO: Her sembol için /fapi/v1/openInterest endpoint'ine paralel istek
                # TODO: OpenInterest model'ine çevir ve yayınla
