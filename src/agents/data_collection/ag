        # TODO: WebSocket pool'u oluştur ve stream'leri ata

    async def _run(self) -> None:
        """Universe değişikliklerini dinle ve WebSocket'leri yönet."""
        self.logger.info("data_collection_loop_started")

        # Universe update stream'ini dinle
        update_task = asyncio.create_task(self._listen_universe_updates())

        # OpenInterest REST poller'ı başlat (WebSocket'te yok)
        oi_task = asyncio.create_task(self._poll_open_interest())

        try:
            await self._stop_event.wait()
        finally:
            update_task.cancel()
            oi_task.cancel()
            await asyncio.gather(update_task, oi_task, return_exceptions=True)

    async def _listen_universe_updates(self) -> None:
