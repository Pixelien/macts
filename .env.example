# =============================================================================
# MACTS - Multi-Agent Crypto Trading System
# Environment Variables Template
# =============================================================================
# UYARI: Bu dosyayı .env olarak kopyalayın ve gerçek değerlerle doldurun.
# .env dosyası ASLA git'e commit edilmemelidir!
# =============================================================================

# -----------------------------------------------------------------------------
# Çalışma Modu (testnet | paper | live)
# -----------------------------------------------------------------------------
MACTS_MODE=testnet
MACTS_ENV=development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Binance API Anahtarları
# -----------------------------------------------------------------------------
# TESTNET (testnet.binancefuture.com adresinden alın)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# MAINNET (sadece paper ve live modlarında kullanılır)
BINANCE_MAINNET_API_KEY=your_mainnet_api_key_here
BINANCE_MAINNET_API_SECRET=your_mainnet_api_secret_here

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=macts
POSTGRES_USER=macts_user
POSTGRES_PASSWORD=change_me_strong_password

# -----------------------------------------------------------------------------
# InfluxDB
# -----------------------------------------------------------------------------
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_ORG=gazifintech
INFLUXDB_BUCKET=macts_market_data
INFLUXDB_TOKEN=change_me_influxdb_token
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change_me_strong_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=macts
KAFKA_CONSUMER_GROUP=macts-agents

# -----------------------------------------------------------------------------
# MLflow Model Registry
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_ARTIFACT_ROOT=s3://macts-models

# -----------------------------------------------------------------------------
# MinIO (S3-uyumlu obje deposu, ML artifact'leri için)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=macts_admin
MINIO_ROOT_PASSWORD=change_me_minio_password
AWS_ACCESS_KEY_ID=macts_admin
AWS_SECRET_ACCESS_KEY=change_me_minio_password

# -----------------------------------------------------------------------------
# Bildirimler
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email (opsiyonel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=macts@gazifintech.local
SMTP_TO=alerts@gazifintech.local

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# -----------------------------------------------------------------------------
# Güvenlik
# -----------------------------------------------------------------------------
# JWT secret (Monitoring API için)
JWT_SECRET=change_me_jwt_secret_min_32_chars_random_string

# Encryption key for sensitive config (Fernet, 32 url-safe base64 bytes)
# Üretmek için: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_fernet_key

# -----------------------------------------------------------------------------
# Performans Tuning
# -----------------------------------------------------------------------------
MAX_WS_CONNECTIONS=10
MAX_SYMBOLS_PER_WS=190
ASYNC_WORKER_COUNT=8

# -----------------------------------------------------------------------------
# AI Analyst (Faz 3) — NVIDIA NIM
# -----------------------------------------------------------------------------
# build.nvidia.com > Get API Key (nvapi- ile başlar). ASLA commit etmeyin!
NVIDIA_API_KEY=your_nvidia_api_key_here
# Feature flag: false iken sistem Faz 2 davranışıyla aynen çalışır
ENABLE_AI_ANALYST=false
# Sembol başına analiz aralığı (saniye). 900 = 15 dk, kota bütçesi için
# docs/AI_ANALYST_MODEL_SELECTION.md §5'e bakın
AI_ANALYST_INTERVAL_SECONDS=900
