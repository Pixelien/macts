{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Agent Up Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "macts_agent_up",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "id": 1
    },
    {
      "title": "Heartbeat Age (seconds)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "time() - macts_agent_heartbeat_timestamp_seconds",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 2
    },
    {
      "title": "Messages Processed Rate (per second)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(macts_agent_messages_processed_total[5m])",
          "legendFormat": "{{agent_name}} / {{channel}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 3
    },
    {
      "title": "Errors per Minute",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(macts_agent_errors_total[5m]) * 60",
          "legendFormat": "{{agent_name}} / {{error_type}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 4
    },
    {
      "title": "Message Processing P95 Latency (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(macts_agent_message_processing_seconds_bucket[5m])) * 1000",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 5
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["macts"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
