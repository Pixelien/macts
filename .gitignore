# =============================================================================
# MACTS .gitignore
# =============================================================================

# Sırlar (KRİTİK!)
.env
.env.local
.env.production
*.pem
*.key
config/config.yaml
secrets/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST
.installed.cfg

# Virtual env
venv/
env/
ENV/
.venv/
.python-version

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints
*.ipynb_checkpoints/
.jupyter/

# ML artifacts
mlruns/
mlartifacts/
*.ckpt
*.pt
*.pth
*.h5
data/checkpoints/*
!data/checkpoints/.gitkeep
data/historical/*
!data/historical/.gitkeep

# Logs
logs/
*.log

# Docker
.docker/
docker-compose.override.yml

# Database dumps
backups/
*.sql.gz
*.dump

# Build helper (geçici)
build_helpers/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Security
.secrets
.tokens
*.pfx
*.cer

# Kod yedekleri (lokal geri alma için, repoya gerek yok)
*.bak
*.bak2
*.bak3
*.bak4
*.bak5

# Backtest çıktıları (opsiyonel — istersen kaldır)
# backtest_results/

